# API keys (optional)
X_BEARER_TOKEN=
NEWS_API_KEY=

# Input image paths
MARKET_REPORT_IMAGE_PATH=portfolio.png
# Optional: comma-separated multi-image mode
MARKET_REPORT_IMAGE_PATHS=

# Output
REPORT_OUTPUT_DIR=./reports

# Extraction strategy
USE_AGENT_EXTRACT_FIRST=true
AGENT_EXTRACT_FILE_PATH=./agent_extracted_holdings.json
USE_LLM_FIRST=true

# LLM extraction (optional)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=45
