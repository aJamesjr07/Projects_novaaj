# Copy to .env and fill values
X_BEARER_TOKEN=
NEWS_API_KEY=
MARKET_REPORT_IMAGE_PATH=portfolio.png
REPORT_OUTPUT_DIR=./reports

# LLM-first screenshot extraction (falls back to OCR on failure)
USE_LLM_FIRST=true
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=45
